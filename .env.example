# Mapbox — get a free token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Google Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Redis — default works if running locally, update for Vultr deployment
REDIS_URL=redis://localhost:6379

# World Labs — get at https://platform.worldlabs.ai/api-keys
# Required for live world generation. Without this, the app uses the demo splat.
WORLDLABS_API_KEY=your_worldlabs_api_key_here

# Google Maps — enable "Street View Static API" at https://console.cloud.google.com
# Required for photo-based world gen. Falls back to text-only generation without it.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
